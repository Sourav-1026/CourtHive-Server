{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2020",
    "lib": ["esnext"],
    "types": ["node"],

    "sourceMap": true,
    "declaration": false,

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": ["index.ts"],
  "exclude": ["node_modules", "dist"]
}